# Agent Skill Depot — environment variables
#
# Copy this file to .env.local for local dev, or set each in Vercel
# (production / preview / development scopes separately).

# ------ Database (Neon) ------
# Production: branch=main. Dev: branch=dev.
# Must point at a Postgres with the pgvector extension enabled.
DATABASE_URL=postgres://user:pass@ep-something.us-east-2.aws.neon.tech/skillhub

# ------ Cloudflare R2 ------
# Create an R2 API token scoped to both prod and dev buckets.
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=skillhub-skills-prod
# Signed URL TTL in seconds (default 300)
R2_SIGNED_URL_TTL=300

# ------ Voyage AI (embeddings) ------
# Used server-side only, for indexing published skills.
VOYAGE_API_KEY=
VOYAGE_MODEL=voyage-3

# ------ Inngest ------
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# ------ Resend (Phase 2, magic-link email) ------
RESEND_API_KEY=
EMAIL_FROM=noreply@AgentSkillDepot.com

# ------ App config ------
# Canonical public URL; used in emails and signed-URL origin checks
NEXT_PUBLIC_APP_URL=https://AgentSkillDepot.com
# API key prefix for agent bearer tokens
AGENT_KEY_PREFIX=skh_live_

# ------ Server-side security ------
# Random 32+ byte secret for hashing API keys before DB lookup
# Generate with: openssl rand -hex 32
API_KEY_HASH_SECRET=

# ------ Optional: sentry, logs, etc. ------
# SENTRY_DSN=
